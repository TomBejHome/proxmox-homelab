proxmox_endpoint         = "https://192.168.10.10:8006/api2/json"
proxmox_api_token_id     = "terraform-prov@pve!tf-token"
proxmox_api_token_secret = "REPLACE_ME"
proxmox_insecure         = true

proxmox_node_name      = "pve"
proxmox_datastore_id   = "local-lvm"
proxmox_network_bridge = "vmbr0"

talos_iso_file_id  = "local:iso/talos.iso"
talos_cluster_name = "gmk-cluster"
talos_version      = "v1.9.2"

talos_nodes = {
  cp-01 = {
    name             = "talos-cp-01"
    role             = "controlplane"
    vm_id            = 200
    cpu_cores        = 2
    memory_dedicated = 8192
    disk_size        = 32
    ipv4_address     = "192.168.10.100/24"
    gateway          = "192.168.10.1"
  }

  worker-01 = {
    name             = "talos-worker-01"
    role             = "worker"
    vm_id            = 201
    cpu_cores        = 4
    memory_dedicated = 8192
    disk_size        = 32
    ipv4_address     = "192.168.10.101/24"
    gateway          = "192.168.10.1"
  }

  worker-02 = {
    name             = "talos-worker-02"
    role             = "worker"
    vm_id            = 202
    cpu_cores        = 4
    memory_dedicated = 8192
    disk_size        = 32
    ipv4_address     = "192.168.10.102/24"
    gateway          = "192.168.10.1"
  }

  worker-03 = {
    name             = "talos-worker-03"
    role             = "worker"
    vm_id            = 203
    cpu_cores        = 4
    memory_dedicated = 8192
    disk_size        = 32
    ipv4_address     = "192.168.10.103/24"
    gateway          = "192.168.10.1"
  }
}
